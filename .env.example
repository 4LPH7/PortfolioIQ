# ============================================================
# PortfolioIQ — Environment Template
# Copy this to .env and fill in your actual values.
# ============================================================

# --- Zerodha Kite Connect ---
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_CLIENT_ID=your_client_id_here
KITE_REDIRECT_URL=http://127.0.0.1:5000/callback

# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolioiq
DB_USER=portfolioiq_user
DB_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://portfolioiq_user:change_me_strong_password@localhost:5432/portfolioiq

# --- Application Settings ---
APP_ENV=development
DRY_RUN_MODE=true
LOG_LEVEL=INFO

# --- Polling Configuration ---
POLLING_INTERVAL_SEC=50
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
EOD_EXPORT_TIME=15:45
TIMEZONE=Asia/Kolkata

# --- Gatekeeper Limits ---
SLIPPAGE_BOUND_PCT=2.0
CONCENTRATION_LIMIT_PCT=15.0
DUPLICATE_WINDOW_SEC=300

# --- Tableau Export ---
TABLEAU_OUTPUT_DIR=./exports/tableau
