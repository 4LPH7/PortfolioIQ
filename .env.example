# PortfolioIQ — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to git.

# ── Database ─────────────────────────────────────────────────────
# PostgreSQL connection string
# Local:    postgresql://portfolioiq:yourpassword@localhost:5432/portfolioiq
# Railway:  Set automatically as DATABASE_URL environment variable
DATABASE_URL=postgresql://portfolioiq:yourpassword@localhost:5432/portfolioiq

# ── Zerodha Kite Connect ──────────────────────────────────────────
# Get these from: https://developers.kite.trade/apps
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_CLIENT_ID=your_zerodha_client_id

# Kite OAuth redirect URL (must match app settings)
KITE_REDIRECT_URL=http://127.0.0.1:5000/callback

# ── Application ───────────────────────────────────────────────────
# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=change_this_to_a_random_secret_key
FLASK_ENV=development   # development | production

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Market Config ─────────────────────────────────────────────────
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
POLLING_INTERVAL_SEC=60

# ── Safety Settings ───────────────────────────────────────────────
# Set to true during testing. false = LIVE orders on Zerodha!
DRY_RUN_MODE=true

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://portfolioiq-4lph7.netlify.app,http://localhost:8080,http://localhost:3000
